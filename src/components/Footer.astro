---
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <span class="text">&copy; {year} <span class="hl">ERIK KLEIMAN</span></span>
    <span class="sep">&mdash;</span>
    <span class="text"><span class="hl">CRAFTED WITH HEART + CAFFEINE</span></span>
    <span class="sep">&mdash;</span>
    <span class="text"><span class="hl">NO CHEAT CODES USED</span></span>
  </div>
</footer>

<style>
  footer {
    border-top: 2px solid #2a0040;
    padding: 24px;
  }

  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 8px;
  }

  .text {
    font-family: 'Press Start 2P', monospace;
    font-size: 7px;
    color: #4a3a6a;
    letter-spacing: 2px;
  }

  .sep {
    color: var(--snes-purple);
    font-size: 7px;
  }

  .hl {
    color: var(--snes-purple);
  }
</style>
